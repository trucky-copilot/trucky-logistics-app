{
  "name": "OrganizationMember",
  "type": "object",
  "properties": {
    "organization_id": {
      "type": "string",
      "description": "ID de la organizaci\u00f3n"
    },
    "user_email": {
      "type": "string",
      "description": "Email del usuario miembro"
    },
    "role": {
      "type": "string",
      "enum": [
        "owner",
        "admin",
        "member"
      ],
      "default": "member",
      "description": "Rol del usuario dentro de la organizaci\u00f3n"
    },
    "active": {
      "type": "boolean",
      "default": true,
      "description": "Si la membres\u00eda est\u00e1 activa"
    }
  },
  "required": [
    "organization_id",
    "user_email",
    "role"
  ]
}