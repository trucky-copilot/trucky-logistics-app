{
  "name": "DispatcherProfile",
  "type": "object",
  "properties": {
    "organization_id": {
      "type": "string",
      "description": "ID de la organizaci\u00f3n a la que pertenece este registro"
    },
    "user_id": {
      "type": "string",
      "description": "Email o ID del usuario dispatcher"
    },
    "dispatch_mode": {
      "type": "string",
      "enum": [
        "single_carrier",
        "multi_carrier"
      ],
      "default": "single_carrier"
    },
    "default_carrier": {
      "type": "string",
      "description": "ID del CarrierProfile por defecto"
    },
    "managed_carriers": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Lista de IDs de CarrierProfiles que gestiona"
    },
    "service_lanes": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Rutas o lanes habituales"
    },
    "preferred_brokers": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "IDs de BrokerProfiles preferidos"
    }
  },
  "required": [
    "user_id"
  ]
}