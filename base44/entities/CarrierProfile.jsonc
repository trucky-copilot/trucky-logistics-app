{
  "name": "CarrierProfile",
  "type": "object",
  "properties": {
    "organization_id": {
      "type": "string",
      "description": "ID de la organizaci\u00f3n a la que pertenece este registro"
    },
    "company_name": {
      "type": "string",
      "description": "Nombre legal de la compa\u00f1\u00eda carrier"
    },
    "trade_name": {
      "type": "string",
      "description": "Nombre comercial o DBA"
    },
    "mc_number": {
      "type": "string",
      "description": "Motor Carrier number (FMCSA)"
    },
    "dot_number": {
      "type": "string",
      "description": "DOT number (FMCSA)"
    },
    "ports_operated": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Puertos donde opera"
    },
    "equipment_types": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Tipos de contenedor que maneja"
    },
    "chassis_types": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Tipos de chasis disponibles"
    },
    "hazmat_allowed": {
      "type": "boolean",
      "default": false
    },
    "overweight_allowed": {
      "type": "boolean",
      "default": false
    },
    "reefer_allowed": {
      "type": "boolean",
      "default": false
    },
    "power_only_allowed": {
      "type": "boolean",
      "default": false
    },
    "commodity_restrictions": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Commodities que NO puede transportar"
    },
    "twic_required": {
      "type": "boolean",
      "default": true
    },
    "active": {
      "type": "boolean",
      "default": true
    }
  },
  "required": [
    "company_name",
    "mc_number"
  ]
}