{
  "name": "UserProfile",
  "type": "object",
  "properties": {
    "usuario": {
      "type": "string",
      "description": "Email del usuario"
    },
    "rol": {
      "type": "string",
      "enum": [
        "carrier",
        "dispatcher",
        "ambos"
      ],
      "default": "dispatcher"
    },
    "cantidad_camiones": {
      "type": "string",
      "enum": [
        "1",
        "2-5",
        "6-10",
        "10+"
      ],
      "default": "1"
    },
    "onboarding_completado": {
      "type": "boolean",
      "default": false
    }
  },
  "required": [
    "usuario"
  ]
}