{
  "name": "Driver",
  "type": "object",
  "properties": {
    "organization_id": {
      "type": "string",
      "description": "ID de la organizaci\u00f3n a la que pertenece este registro"
    },
    "nombre": {
      "type": "string"
    },
    "apellido": {
      "type": "string"
    },
    "telefono": {
      "type": "string"
    },
    "licencia_numero": {
      "type": "string"
    },
    "licencia_vencimiento": {
      "type": "string",
      "format": "date"
    },
    "medico_vencimiento": {
      "type": "string",
      "format": "date"
    },
    "twic_vencimiento": {
      "type": "string",
      "format": "date"
    },
    "hazmat_vencimiento": {
      "type": "string",
      "format": "date"
    },
    "estado": {
      "type": "string",
      "enum": [
        "activo",
        "inactivo",
        "vacaciones",
        "suspension"
      ],
      "default": "activo"
    },
    "truck_asignado": {
      "type": "string",
      "description": "Placa del cami\u00f3n asignado"
    },
    "notas": {
      "type": "string"
    }
  },
  "required": [
    "nombre"
  ]
}